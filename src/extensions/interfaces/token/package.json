{
	"name": "token",
	"description": "Secured token, that is shown to the user only once",
	"icon": "extension",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-custom-interface"
	],
	"type": "module",
	"directus:extension": {
		"type": "interface",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^10.1.1"
	},
	"scripts": {
		"build": "directus-extension build --no-minify",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"test": "echo 'No tests for that extension'",
		"test:dev": "echo 'No tests for that extension'"
	},
	"devDependencies": {
		"@directus/extensions": "^3.0.25",
		"@directus/extensions-sdk": "^17.1.4",
		"@directus/types": "^15.0.3",
		"@types/node": "^22.13.14",
		"sass": "^1.93.2",
		"typescript": "^5.8.3",
		"vue": "^3.5.18",
		"vue-i18n": "^11.1.11"
	}
}
